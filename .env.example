# GPU Configuration
CUDA_VISIBLE_DEVICES=0
DEVICE=cuda

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# Model Paths
MODEL_PATH=./models
LTX2_MODEL_ID=Lightricks/LTX-Video
WAN22_MODEL_ID=damo-viavi/Wan2.2
MULTITALK_MODEL_ID=zyx/MultiTalk

# Generation Defaults
DEFAULT_DURATION=5
DEFAULT_HEIGHT=720
DEFAULT_WIDTH=1280
DEFAULT_FPS=24
DEFAULT_INFERENCE_STEPS=50

# Output Configuration
OUTPUT_PATH=./outputs
MAX_OUTPUT_GB=1000
CLEANUP_OLD_OUTPUTS_DAYS=30

# Frontend URL
FRONTEND_URL=http://localhost:3000
REACT_APP_API_URL=http://localhost:8000

# Database (optional)
DATABASE_URL=sqlite:///./videos.db
